
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>AURORA • Gerador de Rotas ITX</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/modern-normalize/2.0.0/modern-normalize.min.css">
  <style>
    body{font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; background:#f0f9ff; color:#0f172a}
    .wrap{max-width:900px; margin:40px auto; padding:24px; background:#111827; border-radius:12px; box-shadow: 0 10px 30px rgba(0,0,0,.4)}
    h1{font-size:22px; margin:0 0 12px; color:#e2e8f0}
    p.sub{color:#94a3b8; margin-top:0}
    .panel{background:#f0f9ff; border:1px solid #1f2937; padding:16px; border-radius:10px; margin:16px 0}
    label{display:block; margin:8px 0 6px; color:#0f172a}
    input[type=file]{width:100%; padding:10px; background:#0f172a; color:#e2e8f0; border:1px dashed #334155; border-radius:8px}
    .actions{display:flex; gap:12px; margin-top:16px; flex-wrap:wrap}
    button{background:#2563eb; color:white; border:none; padding:10px 16px; border-radius:8px; cursor:pointer}
    button.secondary{background:#334155}
    .flash{background:#7f1d1d; color:#f1f5f9; padding:10px 12px; border-radius:8px; margin:10px 0}
    footer{margin-top:24px; font-size:12px; color:#64748b}
  </style>
</head>
<body>
  <div class="wrap">
    <h1>AURORA • Gerador de Rotas ITX</h1>
    <p class="sub">Envie sua planilha (CSV, XLS ou XLSX) e escolha o que deseja gerar.</p>

    {% with messages = get_flashed_messages() %}
      {% if messages %}
        {% for m in messages %}
          <div class="flash">{{ m }}</div>
        {% endfor %}
      {% endif %}
    {% endwith %}

    <form class="panel" method="post" enctype="multipart/form-data">
      <label>Arquivo de entrada</label>
      <input type="file" name="arquivo" required />

      <div class="actions">
        <button type="submit" formaction="{{ url_for('gerar') }}">Gerar script de configuração</button>
        <button type="submit" class="secondary" formaction="{{ url_for('gerar_planilha') }}">Gerar planilha de ativação</button>
      </div>
    </form>

    <footer>© {{ 2026 }} Gerador de Rotas ITX • AURORA</footer>
  </div>
</body>
</html>


<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>Gerador ITX</title>
</head>
<body>
  <h2>Gerador de Rotas ITX</h2>

  {% with messages = get_flashed_messages() %}
    {% if messages %}
      {% for m in messages %}<p style="color:red">{{ m }}</p>{% endfor %}
    {% endif %}
  {% endwith %}

  <form method="post" action="{{ url_for('gerar') }}" enctype="multipart/form-data">
    <input type="file" name="arquivo" required>
    <button type="submit">Gerar script de configuração</button>
  </form>

  <br>

  <form method="post" action="{{ url_for('gerar_planilha') }}" enctype="multipart/form-data">
    <input type="file" name="arquivo" required>
    <button type="submit">Gerar planilha de ativação</button>
  </form>
</body>
</html>
